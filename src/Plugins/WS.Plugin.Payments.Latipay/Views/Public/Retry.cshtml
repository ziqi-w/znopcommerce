@model RetryPaymentModel
@{
    Layout = "_ColumnsOne";
}

<link rel="stylesheet" href="@Url.Content(LatipayDefaults.Content.PublicStylesheetPath)" />

<div class="page checkout-page latipay-retry-page">
    <div class="page-title">
        <h1>@T("Plugins.Payments.Latipay.Retry.Title")</h1>
    </div>
    <div class="page-body">
        @if (!string.IsNullOrWhiteSpace(Model.OrderNumber))
        {
            <p>
                <strong>@T("Plugins.Payments.Latipay.Retry.OrderLabel")</strong> @Model.OrderNumber
            </p>
        }

        <p class="text-muted">
            @Model.Message
        </p>

        <form asp-action="Retry" asp-route-orderId="@Model.OrderId" method="post">
            <input asp-for="OrderId" type="hidden" />
            <div asp-validation-summary="ModelOnly"></div>

            <div class="form-group latipay-payment-info__selection">
                <div class="latipay-payment-info__label">
                    <label asp-for="SelectedSubPaymentMethod"></label>
                </div>

                <ul class="option-list latipay-option-grid" role="list">
                    @for (var index = 0; index < Model.AvailableSubPaymentMethods.Count; index++)
                    {
                        var method = Model.AvailableSubPaymentMethods[index];
                        var methodId = $"{Html.IdFor(model => model.SelectedSubPaymentMethod)}_{index}";
                        var methodLogoUrl = string.IsNullOrWhiteSpace(method.LogoUrl)
                            ? string.Empty
                            : method.LogoUrl.Replace(".svg", ".png", StringComparison.OrdinalIgnoreCase);

                        <li class="latipay-option-grid__item">
                            @Html.RadioButtonFor(model => model.SelectedSubPaymentMethod, method.Key, new { id = methodId, @class = "latipay-option-card__input" })
                            <label class="latipay-option-card" for="@methodId">
                                <span class="latipay-option-card__logo">
                                    <img src="@Url.Content(methodLogoUrl)" alt="" width="120" height="72" loading="lazy" />
                                </span>
                                <span class="latipay-option-card__details">
                                    <span class="latipay-option-card__indicator" aria-hidden="true"></span>
                                    <span class="latipay-option-card__copy">
                                        <span class="latipay-option-card__title">@method.DisplayName</span>
                                        <span class="latipay-option-card__meta">@T("Plugins.Payments.Latipay.PaymentMethodDescription")</span>
                                    </span>
                                </span>
                            </label>
                        </li>
                    }
                </ul>

                <span class="field-validation-error" asp-validation-for="SelectedSubPaymentMethod"></span>
            </div>

            <button type="submit" class="button-1 checkout-button" @(Model.CanRetry && Model.AvailableSubPaymentMethods.Count > 0 ? null : "disabled")>
                @T("Order.RetryPayment")
            </button>
        </form>
    </div>
</div>
