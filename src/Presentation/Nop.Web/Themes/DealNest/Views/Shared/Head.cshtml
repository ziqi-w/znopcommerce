@using Nop.Core.Domain.Catalog
@using Nop.Services.Helpers

@inject CatalogSettings catalogSettings
@inject IThemeContext themeContext

@{
    Layout = "";
    var themeName = await themeContext.GetWorkingThemeNameAsync();
    var supportRtl = await Html.ShouldUseRtlThemeAsync();

    // Base theme stylesheet
    NopHtml.AppendCssFileParts($"~/Themes/{themeName}/Content/css/styles{(supportRtl ? ".rtl" : "")}.css");

    // Optional swiper support for multi-image product cards
    if (catalogSettings.DisplayAllPicturesOnCatalogPages)
    {
        NopHtml.AppendCssFileParts("~/lib_npm/swiper/swiper-bundle.min.css");
    }

    NopHtml.AppendCssFileParts("~/lib_npm/jquery-ui-dist/jquery-ui.min.css");

    // Theme enhancements loaded after the baseline for easier maintenance and refinement
    NopHtml.AppendCssFileParts($"~/Themes/{themeName}/Content/css/dealnest.css");
    NopHtml.AppendScriptParts(ResourceLocation.Footer, $"~/Themes/{themeName}/Scripts/dealnest.js");
}
