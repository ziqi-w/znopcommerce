@model IList<ProductOverviewModel>

@if (Model.Count > 0)
{
    <section class="product-grid bestsellers">
        <div class="section-heading">
            <span class="eyebrow">Popular right now</span>
            <h2>@T("Bestsellers")</h2>
            <p>Promote proven performers with the same reusable product cards used across category and related product grids.</p>
        </div>
        <div class="item-grid">
            @foreach (var item in Model)
            {
                <div class="item-box">
                    @await Html.PartialAsync("_ProductBox", item)
                </div>
            }
        </div>
    </section>
}
