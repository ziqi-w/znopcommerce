@model CompareProductsModel

@using Nop.Core.Domain.Catalog

@{
    Layout = "_ColumnsTwo";

    NopHtml.AddTitleParts(T("PageTitle.CompareProducts").Text);
    NopHtml.AppendPageCssClassParts("html-compare-products-page");
}

@{
    var columnWidth = "";
    if (Model.Products.Count > 0)
    {
        columnWidth = Math.Round((decimal)(90M / Model.Products.Count), 0).ToString() + "%";
    }

    var uniqueGroupes = new List<ProductSpecificationAttributeGroupModel>();
    foreach (var group in Model.Products.SelectMany(p => p.ProductSpecificationModel.Groups))
    {
        if (!uniqueGroupes.Any(g => g.Id == group.Id))
            uniqueGroupes.Add(group);
    }
}

@* Custom theme compare page override to preserve the table on larger screens and render mobile-friendly product cards on smaller screens. *@
<div class="page compare-products-page">
    <div class="page-title">
        <h1>@T("Products.Compare.Title")</h1>
    </div>
    <div class="page-body">
        @if (Model.Products.Count > 0)
        {
            <div class="compare-products-actions">
                <a href="#" onclick="setLocation('@Url.RouteUrl(NopRouteNames.Standard.CLEAR_COMPARE_LIST)'); return false;" class="button-2 clear-list">@T("Products.Compare.Clear")</a>
            </div>

            <div class="compare-products-desktop">
                <div class="table-wrapper">
                    <table class="compare-products-table">
                        <tbody>
                            <tr class="remove-product">
                                <td class="empty">&nbsp;</td>
                                @foreach (var product in Model.Products)
                                {
                                    <td style="width: @columnWidth;">
                                        <button type="button" class="button-2 remove-button" onclick="setLocation('@Url.RouteUrl(NopRouteNames.Standard.REMOVE_PRODUCT_FROM_COMPARE_LIST, new { productId = product.Id })')">@T("Common.Remove")</button>
                                    </td>
                                }
                            </tr>
                            <tr class="product-picture">
                                <td class="empty">&nbsp;</td>
                                @foreach (var product in Model.Products)
                                {
                                    var picture = product.PictureModels.FirstOrDefault();
                                    <td style="width: @columnWidth;">
                                        <a class="picture" href="@(await NopUrl.RouteGenericUrlAsync<Product>(new { SeName = product.SeName }))"><img alt="@picture?.AlternateText" src="@picture?.ImageUrl" title="@picture?.Title" /></a>
                                    </td>
                                }
                            </tr>
                            <tr class="product-name">
                                <td>
                                    <label>@T("Products.Compare.Name")</label>
                                </td>
                                @foreach (var product in Model.Products)
                                {
                                    <td style="width: @columnWidth;">
                                        <a href="@(await NopUrl.RouteGenericUrlAsync<Product>(new { SeName = product.SeName }))">@product.Name</a>
                                    </td>
                                }
                            </tr>
                            <tr class="product-price">
                                <td>
                                    <label>@T("Products.Compare.Price")</label>
                                </td>
                                @foreach (var product in Model.Products)
                                {
                                    <td style="width: @columnWidth;">
                                        @product.ProductPrice.Price
                                    </td>
                                }
                            </tr>
                            @if (Model.IncludeShortDescriptionInCompareProducts)
                            {
                                <tr class="short-description">
                                    <td>
                                        <label>@T("Products.Compare.ShortDescription")</label>
                                    </td>
                                    @foreach (var product in Model.Products)
                                    {
                                        <td style="width: @columnWidth;">
                                            @Html.Raw(product.ShortDescription)
                                        </td>
                                    }
                                </tr>
                            }
                            @if (Model.IncludeFullDescriptionInCompareProducts)
                            {
                                <tr class="full-description">
                                    <td>
                                        <label>@T("Products.Compare.FullDescription")</label>
                                    </td>
                                    @foreach (var product in Model.Products)
                                    {
                                        <td style="width: @columnWidth;">
                                            @Html.Raw(product.FullDescription)
                                        </td>
                                    }
                                </tr>
                            }
                            @foreach (var group in uniqueGroupes)
                            {
                                if (group.Attributes.Count > 0)
                                {
                                    @if (group.Id > 0)
                                    {
                                        <tr class="specification-group">
                                            <td>
                                                <label>@group.Name</label>
                                            </td>
                                        </tr>
                                    }

                                    var uniqueGroupAttributes = new List<ProductSpecificationAttributeModel>();
                                    foreach (var specAttribute in Model.Products.SelectMany(p => p.ProductSpecificationModel.Groups.Where(g => g.Id == group.Id).SelectMany(g => g.Attributes)))
                                    {
                                        if (!uniqueGroupAttributes.Any(sa => sa.Id == specAttribute.Id))
                                            uniqueGroupAttributes.Add(specAttribute);
                                    }
                                    @foreach (var specificationAttribute in uniqueGroupAttributes)
                                    {
                                        <tr class="specification">
                                            <td>
                                                <label>@specificationAttribute.Name</label>
                                            </td>
                                            @foreach (var product in Model.Products)
                                            {
                                                var foundProductSpec = product.ProductSpecificationModel.Groups
                                                    .Where(g => g.Id == group.Id)
                                                    .SelectMany(g => g.Attributes)
                                                    .FirstOrDefault(sa => sa.Id == specificationAttribute.Id);

                                                <td style="width: @columnWidth;">
                                                    @if (foundProductSpec != null)
                                                    {
                                                        for (int i = 0; i < foundProductSpec.Values.Count; i++)
                                                        {
                                                            var value = foundProductSpec.Values[i];

                                                            if (string.IsNullOrEmpty(value.ColorSquaresRgb))
                                                            {
                                                                @Html.Raw(value.ValueRaw)
                                                                if (i != foundProductSpec.Values.Count - 1)
                                                                {
                                                                    <text>,&nbsp;</text>
                                                                }
                                                            }
                                                            else
                                                            {
                                                                <div class="attribute-squares color-squares attribute-squares-padding">
                                                                    <span class="attribute-square-container" title="@Html.Raw(value.ValueRaw)">
                                                                        <span class="attribute-square" style="background-color: @(value.ColorSquaresRgb);">&nbsp;</span>
                                                                    </span>
                                                                </div>
                                                            }
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <text>&nbsp;</text>
                                                    }
                                                </td>
                                            }
                                        </tr>
                                    }
                                }
                            }
                        </tbody>
                    </table>
                </div>
            </div>

            <div class="compare-products-mobile">
                @foreach (var product in Model.Products)
                {
                    var picture = product.PictureModels.FirstOrDefault();

                    <article class="compare-product-card">
                        <div class="compare-product-card__header">
                            <a class="compare-product-card__picture" href="@(await NopUrl.RouteGenericUrlAsync<Product>(new { SeName = product.SeName }))">
                                <img alt="@picture?.AlternateText" src="@picture?.ImageUrl" title="@picture?.Title" />
                            </a>
                            <div class="compare-product-card__summary">
                                <a href="@(await NopUrl.RouteGenericUrlAsync<Product>(new { SeName = product.SeName }))" class="compare-product-card__name">@product.Name</a>
                                <div class="compare-product-card__price-row">
                                    <span class="compare-product-card__label">@T("Products.Compare.Price")</span>
                                    <span class="compare-product-card__price">@product.ProductPrice.Price</span>
                                </div>
                            </div>
                        </div>

                        @if (Model.IncludeShortDescriptionInCompareProducts && !string.IsNullOrWhiteSpace(product.ShortDescription))
                        {
                            <div class="compare-product-card__section">
                                <div class="compare-product-card__section-title">@T("Products.Compare.ShortDescription")</div>
                                <div class="compare-product-card__copy">@Html.Raw(product.ShortDescription)</div>
                            </div>
                        }

                        @if (Model.IncludeFullDescriptionInCompareProducts && !string.IsNullOrWhiteSpace(product.FullDescription))
                        {
                            <div class="compare-product-card__section">
                                <div class="compare-product-card__section-title">@T("Products.Compare.FullDescription")</div>
                                <div class="compare-product-card__copy">@Html.Raw(product.FullDescription)</div>
                            </div>
                        }

                        @foreach (var group in product.ProductSpecificationModel.Groups.Where(g => g.Attributes.Count > 0))
                        {
                            <div class="compare-product-card__section">
                                @if (group.Id > 0)
                                {
                                    <div class="compare-product-card__section-title">@group.Name</div>
                                }
                                <dl class="compare-product-card__specs">
                                    @foreach (var specAttribute in group.Attributes)
                                    {
                                        <div class="compare-product-card__spec">
                                            <dt>@specAttribute.Name</dt>
                                            <dd>
                                                @for (int i = 0; i < specAttribute.Values.Count; i++)
                                                {
                                                    var value = specAttribute.Values[i];

                                                    if (string.IsNullOrEmpty(value.ColorSquaresRgb))
                                                    {
                                                        @Html.Raw(value.ValueRaw)
                                                        if (i != specAttribute.Values.Count - 1)
                                                        {
                                                            <text>,&nbsp;</text>
                                                        }
                                                    }
                                                    else
                                                    {
                                                        <span class="attribute-squares color-squares attribute-squares-padding">
                                                            <span class="attribute-square-container" title="@Html.Raw(value.ValueRaw)">
                                                                <span class="attribute-square" style="background-color: @(value.ColorSquaresRgb);">&nbsp;</span>
                                                            </span>
                                                        </span>
                                                    }
                                                }
                                            </dd>
                                        </div>
                                    }
                                </dl>
                            </div>
                        }

                        <div class="compare-product-card__actions">
                            <button type="button" class="button-2 remove-button" onclick="setLocation('@Url.RouteUrl(NopRouteNames.Standard.REMOVE_PRODUCT_FROM_COMPARE_LIST, new { productId = product.Id })')">@T("Common.Remove")</button>
                        </div>
                    </article>
                }
            </div>
        }
        else
        {
            <div class="no-data">
                @T("Products.Compare.NoItems")
            </div>
        }
    </div>
</div>
